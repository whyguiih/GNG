<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A soma dos números é:"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/tvSomaResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FF0000"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etPalpite1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Palpite do número 1"
        android:inputType="number"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etPalpite2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Palpite do número 2"
        android:inputType="number"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnVerificar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verificar"/>

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voltar"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvMensagemFinal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

</LinearLayout>